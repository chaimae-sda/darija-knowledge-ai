# Mistral API key — used for OCR (image/PDF text extraction via Pixtral)
# Get yours at: https://console.mistral.ai/
VITE_MISTRAL_API_KEY=your_mistral_api_key_here

# HuggingFace API key — used for Darija translation
# Primary model: atlasia/Terjman-Ultra-v2.0 (gated — request access at https://huggingface.co/atlasia/Terjman-Ultra-v2.0)
# Fallback model: atlasia/Terjman-Large (public — used automatically if the primary model returns 401/403)
# Get your token at: https://huggingface.co/settings/tokens
VITE_HF_API_KEY=your_huggingface_api_key_here
